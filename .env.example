# ── LLM 后端（vLLM，llm-01 本机）────────────────────────────────────────────────────
# 默认使用本机 vLLM 上的 Gemma 4 27B IT
# vLLM 服务监听 :8000，n8n 通过 host.docker.internal 访问
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_API_KEY=token-vidpipe
LLM_MODEL=gemma-4-27b-it

# 如果用 Ollama 替代 vLLM，取消注释以下三行
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma4

# ── ComfyUI（llm-02，填写实际 IP 或主机名）────────────────────────────────────────────
# 例如：COMFYUI_URL=http://192.168.1.102:8188
COMFYUI_URL=http://host.docker.internal:8188

# ── 视频生成超时控制 ──────────────────────────────────────────────────────────────────
# 单次最长等待时间（秒）
# LTX 2.3 Distilled GGUF Q4_K_M 在 RTX 4090 上约 60-90s，设 180 留足余量
COMFY_TIMEOUT_SEC=180

# 超时后最多重试次数（每次退避 30s * attempt）
COMFY_MAX_RETRIES=2

# ── 视频存储 ──────────────────────────────────────────────────────────────────────────
SAU_VIDEO_DIR=/data/videos

# ── 发布平台后端 (SAU) ───────────────────────────────────────────────────────────────
SAU_API_URL=http://sau-backend:8080

# ── HuggingFace Token（用于下载模型）─────────────────────────────────────────────────
# GGUF 模型（unsloth/LTX-2.3-GGUF）无需特殊协议，登录即可下载
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
