# ════════════════════════════════════════════════════════════════════════════════
# 网络拓扑说明
# ════════════════════════════════════════════════════════════════════════════════
# llm-01  无线: llm-01.localdomain   千兆有线: llm-01.tbd   100G IB: 10.0.0.1
#         运行: n8n + vLLM (Gemma 4) + sau-backend
#
# llm-02  无线: llm-02.localdomain   千兆有线: llm-02.tbd   100G IB: 10.0.0.2
#         运行: ComfyUI (LTX 2.3 GGUF)
#
# n8n 访问 vLLM:    同机，走 host.docker.internal:8000
# n8n 访问 ComfyUI: 跨机，走 IB 直连 10.0.0.2:8188（最低延迟）
#                   备用千兆: llm-02.tbd:8188
# sau-backend 登录: 远程控制 Mac/Windows Chrome，详见 sau-backend/README.md
# ════════════════════════════════════════════════════════════════════════════════

# ── LLM 后端（vLLM，llm-01 本机）────────────────────────────────────────────────
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_API_KEY=token-vidpipe
LLM_MODEL=gemma-4-27b-it

# 如果用 Ollama 替代 vLLM，取消注释以下三行
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma4

# ── ComfyUI（llm-02）─────────────────────────────────────────────────────────────
COMFYUI_URL=http://10.0.0.2:8188
# 备用千兆有线:
# COMFYUI_URL=http://llm-02.tbd:8188
# 备用无线（调试用，带宽低勿传大文件）:
# COMFYUI_URL=http://llm-02.localdomain:8188

# ── 视频生成超时控制 ──────────────────────────────────────────────────────────────
COMFY_TIMEOUT_SEC=180
COMFY_MAX_RETRIES=2

# ── 视频存储 ──────────────────────────────────────────────────────────────────────
SAU_VIDEO_DIR=/data/videos

# ── 发布平台后端 (SAU) ───────────────────────────────────────────────────────────
# sau-backend 部署在 llm-01 Docker 内部，n8n 通过容器内网访问，不需要对外暗口
SAU_API_URL=http://sau-backend:8080

# sau-backend 登录时远程控制 Chrome 的地址（可注册多个，逗号分隔）
# 详见 sau-backend/README.md
SAU_CDP_CLIENTS=http://192.168.1.100:9222

# ── n8n 基础配置 ─────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme
N8N_ENCRYPTION_KEY=changeme
N8N_HOST=llm-01.localdomain
N8N_PROTOCOL=http
WEBHOOK_URL=http://llm-01.localdomain:5678
N8N_RUNNERS_AUTH_TOKEN=changeme

# ── HuggingFace Token（用于下载模型）─────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
