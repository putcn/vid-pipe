# ══════════════════════════════════════════
# VidPipe 环境变量配置
# 复制为 .env 后按实际情况填写
# ══════════════════════════════════════════

# ── PostgreSQL（运行在 llm-01）──
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_strong_password

# ── n8n 安全 ──
N8N_ENCRYPTION_KEY=change_this_32char_key_abcdefghij
N8N_RUNNERS_AUTH_TOKEN=change_this_runner_token

# ── n8n 地址（运行在 llm-01）──
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ── HuggingFace Token（下载 Gemma4 和 LTX 模型都需要）──
# 在 https://huggingface.co/settings/tokens 获取
# 需要先在 HF 接受 Gemma4 和 LTX-Video 的使用协议
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════
# LLM 配置（llm-01 上的 vLLM Gemma4，三选一取消注释）
# ══════════════════════════════════════════

# 【推荐】本地 vLLM（llm-01，docker-compose.vllm.yml 启动）
# llm-01 和 llm-02 在同一局域网时，n8n 容器通过 llm-01 的 IP 访问
LLM_BASE_URL=http://llm-01:8000/v1
LLM_API_KEY=token-abc123
LLM_MODEL=gemma4

# 本地 Ollama（备用）
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma4:27b-it-q4_K_M

# 云端 OpenAI（调试用）
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o

# 云端 DeepSeek（备用）
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=your-deepseek-key
# LLM_MODEL=deepseek-chat

# ══════════════════════════════════════════
# ComfyUI 配置（llm-02，docker-compose.comfyui.yml 启动）
# ══════════════════════════════════════════

# llm-02 的 IP 或主机名（n8n 从 llm-01 远程调用）
COMFYUI_URL=http://llm-02:8188

# ══════════════════════════════════════════
# 视频存储路径（sau-backend 容器内路径）
# ══════════════════════════════════════════
SAU_VIDEO_DIR=/data/videos
SAU_COOKIE_DIR=/data/cookies
