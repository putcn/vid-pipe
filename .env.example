# ── LLM 后端 ──────────────────────────────────────────────────────────────────
# Ollama (本地)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma4

# vLLM (本地，更稳定的 JSON 输出)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=token-abc
# LLM_MODEL=gemma4

# ── ComfyUI ───────────────────────────────────────────────────────────────────
COMFYUI_URL=http://host.docker.internal:8188

# 视频生成超时控制
# 单次最长等待时间（秒）。LTX 2.3 Distilled 在 RTX 4090 上约 90-180s
# 建议设为 300（5分钟），给足余量
COMFY_TIMEOUT_SEC=300

# 超时后最多重试次数（每次退避 30s * attempt）
COMFY_MAX_RETRIES=2

# ── 视频存储 ──────────────────────────────────────────────────────────────────
SAU_VIDEO_DIR=/data/videos

# ── 发布平台后端 (SAU) ────────────────────────────────────────────────────────
SAU_API_URL=http://sau-backend:8080

# ── n8n 全局超时（docker-compose environment 里设置）─────────────────────────
# 给 workflow 足够长的时间：单次生成最多重试2次 × (5min + 60s退避) ≈ 18min
# 建议设为 1800（30分钟）
# EXECUTIONS_TIMEOUT=1800
# EXECUTIONS_TIMEOUT_MAX=3600
