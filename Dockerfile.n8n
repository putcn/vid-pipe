# n8n v2 的镜像是 distroless Alpine，移除了 apk 和 apt-get
# 解决方法: multi-stage build
#   Stage 1: 用标准 Alpine 安装工具和 Python 包
#   Stage 2: 将产物 COPY 进 n8n 镜像

# ── Stage 1: builder ──
FROM alpine:3.20 AS builder

RUN apk add --no-cache \
    python3 py3-pip python3-dev \
    build-base g++ libffi-dev openssl-dev \
    ffmpeg curl

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --no-cache-dir \
    httpx requests beautifulsoup4 feedparser \
    openai anthropic Pillow numpy pandas python-dotenv

# ── Stage 2: final ──
FROM docker.n8n.io/n8nio/n8n:latest

USER root

# 从 builder 拷贝 Python 运行时和已安装的包
COPY --from=builder /usr/bin/python3 /usr/bin/python3
COPY --from=builder /usr/lib/python3* /usr/lib/python3/
COPY --from=builder /opt/venv /opt/venv
# ffmpeg 静态二进制直接拷贝
COPY --from=builder /usr/bin/ffmpeg /usr/bin/ffmpeg
COPY --from=builder /usr/bin/ffprobe /usr/bin/ffprobe

ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

USER node
