# ── Stage 1: builder (Alpine) ──
# 仅用于安装第三方 Python 包到 /opt/venv
FROM alpine:3.20 AS builder

RUN apk add --no-cache python3 py3-pip python3-dev build-base

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --no-cache-dir \
    httpx requests beautifulsoup4 feedparser \
    openai anthropic Pillow numpy pandas python-dotenv

# ── Stage 2: final ──
# 使用官方 task runner 镜像作为基础，已内置 Python + shell
# n8n v2.x 的 n8nio/n8n 是 distroless，没有包管理器，不能用作 base
FROM n8nio/n8n-task-runners:latest

USER root

# 只复制 venv（第三方包），标准库由 base 镜像自带
COPY --from=builder /opt/venv /opt/venv

ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

USER node
