FROM n8nio/runners:latest

USER root

# uv 已内置在镜像里，用它安装第三方包到官方 venv
RUN uv pip install --python /opt/runners/task-runner-python/.venv/bin/python --no-cache \
    httpx requests beautifulsoup4 feedparser \
    openai anthropic Pillow numpy pandas python-dotenv

# 覆盖默认配置，修正 args 和开放 external allow
COPY n8n-task-runners.json /etc/n8n-task-runners.json

USER runner
