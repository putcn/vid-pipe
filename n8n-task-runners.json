{
  "task-runners": [
    {
      "runner-type": "javascript",
      "workdir": "/opt/runners/task-runner-javascript",
      "command": "/usr/local/bin/node",
      "args": ["/opt/runners/task-runner-javascript/dist/start.js"],
      "health-check-server-port": "9091",
      "allowed-env": [
        "PATH",
        "N8N_RUNNERS_GRANT_TOKEN",
        "N8N_RUNNERS_TASK_BROKER_URI",
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "NODE_FUNCTION_ALLOW_BUILTIN",
        "NODE_FUNCTION_ALLOW_EXTERNAL"
      ],
      "env-overrides": {
        "NODE_FUNCTION_ALLOW_BUILTIN": "*",
        "NODE_FUNCTION_ALLOW_EXTERNAL": "*"
      }
    },
    {
      "runner-type": "python",
      "workdir": "/opt/runners/task-runner-python",
      "command": "/opt/runners/task-runner-python/.venv/bin/python",
      "args": ["-m", "task_runner_python"],
      "health-check-server-port": "9092",
      "allowed-env": [
        "PATH",
        "N8N_RUNNERS_GRANT_TOKEN",
        "N8N_RUNNERS_TASK_BROKER_URI",
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "N8N_RUNNERS_STDLIB_ALLOW",
        "N8N_RUNNERS_EXTERNAL_ALLOW",
        "LLM_BASE_URL",
        "LLM_API_KEY",
        "LLM_MODEL",
        "COMFYUI_URL",
        "SAU_API_URL",
        "SAU_VIDEO_DIR"
      ],
      "env-overrides": {
        "PYTHONPATH": "/opt/runners/task-runner-python",
        "N8N_RUNNERS_STDLIB_ALLOW": "*",
        "N8N_RUNNERS_EXTERNAL_ALLOW": "httpx,requests,beautifulsoup4,bs4,feedparser,openai,anthropic,PIL,Pillow,numpy,pandas,python-dotenv,dotenv"
      }
    }
  ]
}
